@model EVotingSystem.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="content-card auth-card">
    <span class="eyebrow">Voter Login</span>
    <h1 class="display-6 fw-bold mb-3">Sign in to access your ballot</h1>
    <p class="text-secondary mb-4">Identity cookies and secure password hashing are configured through ASP.NET Core Identity. This starter uses the Identity managers directly so the move from placeholder storage to Firestore-backed user persistence stays predictable.</p>

    <form asp-action="Login" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control form-control-lg" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control form-control-lg" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="d-flex flex-column flex-sm-row gap-3">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-4">Login</button>
            <a class="btn btn-outline-dark btn-lg rounded-pill px-4" asp-action="Register">Create account</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
