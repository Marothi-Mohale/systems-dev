@model EVotingSystem.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="form-shell">
    <div class="form-panel compact">
        <span class="eyebrow">Secure Sign In</span>
        <h1>Return to your ballot</h1>

        <form asp-action="Login" method="post" class="election-form">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-accent">Sign in</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
