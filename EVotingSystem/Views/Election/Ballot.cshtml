@model EVotingSystem.Models.ViewModels.VoteViewModel
@{
    ViewData["Title"] = "Ballot";
}

<section class="content-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <span class="eyebrow">Authenticated Voter Area</span>
            <h1 class="display-6 fw-bold mb-2">@Model.VoterName's ballot</h1>
            <p class="text-secondary mb-0">This page is protected by ASP.NET Core Identity. The voting rules are explicit in the model: one authenticated, eligible voter gets one vote during the election window.</p>
        </div>
        <div class="mini-stat">
            <span class="stat-label">Election</span>
            <strong class="stat-value small-value">@Model.Election.Title</strong>
        </div>
    </div>

    <div class="feature-panel mb-4">
        <div class="d-flex flex-wrap gap-4">
            <span><strong>Voting window:</strong> @Model.Election.StartsAtUtc.ToLocalTime():g to @Model.Election.EndsAtUtc.ToLocalTime():g</span>
            <span><strong>Max votes per voter:</strong> @Model.VotingRules.MaxVotesPerVoterPerElection</span>
            <span><strong>Status:</strong> @(Model.CanSubmitVote ? "Open for voting" : "Unavailable")</span>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var candidate in Model.Candidates)
        {
            <div class="col-12 col-lg-4">
                <article class="candidate-card h-100">
                    <span class="candidate-party">@candidate.Party</span>
                    <h2 class="h4">@candidate.Name</h2>
                    <p class="fw-semibold">@candidate.Slogan</p>
                    <p class="text-secondary mb-0">@candidate.Biography</p>
                </article>
            </div>
        }
    </div>
</section>
