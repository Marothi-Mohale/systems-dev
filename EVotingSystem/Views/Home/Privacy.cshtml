@{
    ViewData["Title"] = "Privacy";
}

<section class="content-card narrow-card">
    <span class="eyebrow">Privacy</span>
    <h1 class="display-6 fw-bold mb-3">Prototype privacy posture</h1>
    <p class="text-secondary">This starter is configured to use ASP.NET Core Identity for authentication and is designed so sensitive data access can stay on the server side. Firestore and Mailcheck.ai integrations should be wired through services rather than accessed directly from the browser.</p>
    <p class="text-secondary mb-0">Before production use, add HTTPS enforcement, secret storage, lockout rules, audit logging, and a privacy review for voter and ballot data handling.</p>
</section>
