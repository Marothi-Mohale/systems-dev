@model EVotingSystem.Models.ViewModels.PublicDashboardViewModel
@{
    ViewData["Title"] = "Public Results";
}

<section class="hero-card mb-4 mb-lg-5">
    <div class="row g-4 align-items-center">
        <div class="col-lg-7">
            <span class="eyebrow">Public Election Dashboard</span>
            <h1 class="display-5 fw-bold mb-3">@Model.Election.Title</h1>
            <p class="lead text-secondary mb-4">@Model.Election.Description</p>
            <div class="d-flex flex-wrap gap-3">
                <a class="btn btn-primary btn-lg rounded-pill px-4" asp-controller="Account" asp-action="Register">Register to Vote</a>
                <a class="btn btn-outline-dark btn-lg rounded-pill px-4" asp-controller="Account" asp-action="Login">Voter Login</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="stats-panel">
                <div>
                    <span class="stat-label">Total Votes</span>
                    <strong class="stat-value">@Model.TotalVotes</strong>
                </div>
                <div>
                    <span class="stat-label">Turnout</span>
                    <strong class="stat-value">@Model.PopulationTurnoutPercentage%</strong>
                </div>
                <div>
                    <span class="stat-label">Election Status</span>
                    <strong class="stat-value">@(Model.ElectionOpen ? "Open" : "Closed")</strong>
                </div>
                <div>
                    <span class="stat-label">Last Refreshed</span>
                    <strong class="stat-value">@Model.GeneratedAtUtc.ToLocalTime().ToString("g")</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="row g-4">
    @foreach (var result in Model.Results)
    {
        <div class="col-12 col-lg-4">
            <article class="candidate-card h-100">
                <span class="candidate-party">@result.Party</span>
                <h2 class="h4 mb-3">@result.CandidateName</h2>
                <div class="progress result-progress mb-3" role="progressbar" aria-label="@result.CandidateName vote share" aria-valuenow="@result.VotePercentage" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" style="width: @result.VotePercentage%;"></div>
                </div>
                <div class="d-flex justify-content-between text-secondary">
                    <span>@result.VoteCount votes</span>
                    <span>@result.VotePercentage%</span>
                </div>
            </article>
        </div>
    }
</section>

<section class="row g-4 mt-1">
    <div class="col-lg-6">
        <div class="feature-panel h-100">
            <h2 class="h4">Architecture-ready starter</h2>
            <p class="text-secondary mb-0">Identity, configuration, logging, and global exception handling are wired up so Firestore repositories and Mailcheck.ai validation can be integrated without restructuring the app later.</p>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="feature-panel h-100">
            <h2 class="h4">Next integration points</h2>
            <p class="text-secondary mb-0">Connect candidate reads, voter profiles, and vote transactions to Firestore, then replace the placeholder email validator with the live Mailcheck.ai client.</p>
        </div>
    </div>
</section>
