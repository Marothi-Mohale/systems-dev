@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="content-card narrow-card">
    <span class="eyebrow text-danger">Application Error</span>
    <h1 class="display-6 fw-bold mb-3">Something went wrong.</h1>
    <p class="text-secondary">The app is configured with a global exception handling path so unexpected failures resolve to a controlled MVC error page instead of leaking raw exception details in production.</p>

    @if (!string.IsNullOrWhiteSpace(Model.RequestId))
    {
        <p class="mb-0"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
</section>
