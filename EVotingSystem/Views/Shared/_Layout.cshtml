<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Election Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Source+Serif+4:opsz,wght@8..60,600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="site-header sticky-top">
            <nav class="navbar navbar-expand-lg container py-3">
                <a class="navbar-brand d-flex flex-column" asp-controller="Home" asp-action="Index">
                    <span class="brand-overline">Civic Tech Prototype</span>
                    <span class="brand-title">Election Platform</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#primaryNav" aria-controls="primaryNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="primaryNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2 nav-pills-shell">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Results" asp-action="Index">Results</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Election" asp-action="Ballot">Ballot</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-dark rounded-pill px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-link nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary rounded-pill px-4" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </nav>
        </header>

        <main class="container py-4 py-lg-5">
            @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-success shadow-sm app-alert" role="alert">
                    @statusMessage
                </div>
            }

            @RenderBody()
        </main>

        <footer class="site-footer mt-auto">
            <div class="container py-4 py-lg-5">
                <div class="row g-4 align-items-start">
                    <div class="col-lg-5">
                        <span class="brand-overline text-white-50">Election Platform</span>
                        <h2 class="footer-title mt-2">Professional demo-ready civic technology interface.</h2>
                        <p class="footer-copy mb-0">Built with ASP.NET Core MVC, Identity, Firestore integration, and a public results experience that is easy for markers and guests to understand.</p>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <h3 class="footer-heading">Explore</h3>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a asp-controller="Results" asp-action="Index">Results</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        </ul>
                    </div>
                    <div class="col-sm-6 col-lg-4">
                        <h3 class="footer-heading">Demo Notes</h3>
                        <p class="footer-copy mb-2">Population baseline for turnout calculations: 100</p>
                        <p class="footer-copy mb-0">Suggested static assets: store candidate portraits in <code>wwwroot/images/candidates/</code> and branded illustrations in <code>wwwroot/images/ui/</code>.</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
