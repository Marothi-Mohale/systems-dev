{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Identity": "Warning"
    }
  },
  "AllowedHosts": "your-production-hostname",
  "Firebase": {
    "ProjectId": "",
    "DatabaseId": "(default)",
    "ServiceAccountEmail": "",
    "ServiceAccountPrivateKey": "",
    "TokenUri": "https://oauth2.googleapis.com/token"
  },
  "Firestore": {
    "SeedOnStartup": false,
    "Collections": {
      "Elections": "elections",
      "Candidates": "candidates",
      "Votes": "votes",
      "ElectionStats": "electionStats",
      "VoterProfiles": "voterProfiles"
    }
  },
  "MailCheck": {
    "ApiKey": "",
    "BaseUrl": "https://api.mailcheck.ai",
    "VerifyEndpointTemplate": "/email/{email}",
    "TimeoutSeconds": 10,
    "MaxAttempts": 2,
    "RetryBaseDelayMilliseconds": 250,
    "RequireMxRecords": true,
    "RequireDeliverableResult": true,
    "RejectDisposable": true,
    "RejectSpam": true,
    "RejectRisky": true,
    "RejectedRiskLevels": [ "high", "risky", "spam", "malicious", "invalid", "disposable" ]
  },
  "Seed": {
    "Election": {
      "Id": "2026-national-election",
      "Title": "Election Platform",
      "Description": "Production election configuration",
      "StartsAtUtc": "2026-01-10T08:00:00Z",
      "EndsAtUtc": "2026-12-31T23:59:00Z",
      "TotalPopulation": 100
    },
    "Candidates": []
  },
  "Ui": {
    "ApplicationName": "Election Platform",
    "SupportEmail": "support@example.com"
  }
}
